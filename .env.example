PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_secret_key

# Zaakpay Payment Gateway (Express Checkout V13)
# ZAAKPAY_MERCHANT_IDENTIFIER — your Merchant Identifier from the Zaakpay dashboard
# ZAAKPAY_SECRET_KEY         — your Generated Key (used as HMAC-SHA256 secret)
# ZAAKPAY_BASE_URL           — sandbox: https://zaakstaging.zaakpay.com
#                              production: https://www.zaakpay.com
ZAAKPAY_MERCHANT_IDENTIFIER=your_merchant_identifier
ZAAKPAY_SECRET_KEY=your_generated_key
ZAAKPAY_BASE_URL=https://zaakstaging.zaakpay.com

# URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
